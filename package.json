{
  "name": "balanzen-backend",
  "version": "1.3.1",
  "description": "Balanzen API - Express backend",
  "main": "src/index.js",
  "type": "module",
  "imports": {
    "#config/*.js": "./src/config/*.js",
    "#models/*.js": "./src/models/*.js",
    "#services/*.js": "./src/services/*.js",
    "#controllers/*.js": "./src/controllers/*.js",
    "#middlewares/*.js": "./src/middlewares/*.js",
    "#routes/*.js": "./src/routes/*.js",
    "#utils/*.js": "./src/utils/*.js",
    "#assets/*.js": "./src/assets/*.js",
    "#tests/*.js": "./src/tests/*.js",
    "#jobs/*.js": "./src/jobs/*.js"
  },
  "scripts": {
    "dev": "cross-env NODE_ENV=local nodemon src/index.js",
    "start:local": "cross-env NODE_ENV=local node src/index.js",
    "start:testing": "cross-env NODE_ENV=testing node src/index.js",
    "start:prod": "cross-env NODE_ENV=production node src/index.js",
    "start": "node src/index.js",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write src/",
    "test": "vitest",
    "test:run": "vitest run",
    "seed": "cross-env NODE_ENV=local node src/assets/scripts/seed.js",
    "db:reset": "cross-env NODE_ENV=local node src/assets/scripts/reset-db.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cloudinary": "^1.41.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-validator": "^7.3.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.5.1",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "multer-storage-cloudinary": "^4.0.0",
    "node-cron": "^4.2.1",
    "socket.io": "^4.8.3",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "cross-env": "^10.1.0",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.4.0",
    "mongodb-memory-server": "^11.0.1",
    "nodemon": "^3.1.4",
    "prettier": "^3.8.1",
    "supertest": "^7.2.2",
    "vitest": "^4.1.5"
  }
}
